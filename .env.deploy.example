# Voli deploy example — environment variables for `voli serve`.
#
# Copy to `.env.deploy` (gitignored, set this up next to .env if you want)
# or paste the values into your hosting provider's secrets UI directly.
#
# These are loaded by python-dotenv when the CLI starts.

# ----- required ---------------------------------------------------------------

# Static bearer token clients send as `Authorization: Bearer <token>`.
# Generate one with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Anyone with this token can call your tools and burn through your Polygon
# budget, so treat it like an API key. Rotate by setting a new value and
# updating Claude.ai / ChatGPT to match.
VOLI_AUTH_TOKEN=replace_me

# Polygon API key (when the active data provider is the bundled `polygon`).
POLYGON_API_KEY=replace_me

# Public URL where this server will be reachable. Embedded in the OpenAPI
# spec at /openapi.json so ChatGPT Custom GPT Actions know where to call
# back. Required for ChatGPT integration; optional for local testing.
VOLI_SERVER_URL=https://voli.example.com

# ----- optional ---------------------------------------------------------------

# Active data provider. Polygon is the default; forks add others via the
# voli.data_providers entry-point group.
# VOLI_DATA_PROVIDER=polygon

# LLM provider settings (only relevant if you also use `voli llm-ask` on
# this box; the served HTTP surface itself doesn't call any LLM).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# VOLI_LLM_PROVIDER=anthropic
# VOLI_LLM_MODEL=claude-sonnet-4-6

# Where the on-disk SQLite TTL cache lives. The container path should be a
# mounted volume so the cache survives container restarts.
# VOLI_CACHE_PATH=/var/voli/cache.sqlite
# VOLI_TRACE_DIR=/var/voli/traces

# Log level / format. `text` is themed when stderr is a TTY, `json` is
# better for shipping to a log aggregator.
# VOLI_LOG_LEVEL=INFO
# VOLI_LOG_FORMAT=json
