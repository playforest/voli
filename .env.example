# Voli — example .env.
#
# Copy to `.env` (gitignored). Loaded by the CLI on startup via python-dotenv.
# Anything you set here wins over config.yaml.

# ----- secrets ----------------------------------------------------------------

# Required when the active data provider is Polygon (the default).
POLYGON_API_KEY=replace_me

# Required for `voli llm-ask --provider anthropic` and the MCP server when
# chatting via Claude Desktop / claude.ai.
# ANTHROPIC_API_KEY=replace_me

# Required for `voli llm-ask --provider openai`.
# OPENAI_API_KEY=replace_me

# ----- providers --------------------------------------------------------------

# Active data provider. Polygon ships in core; forks add others via the
# voli.data_providers entry-point group.
# VOLI_DATA_PROVIDER=polygon

# Default LLM provider when --provider isn't passed (anthropic | openai | a
# third-party name registered via voli.llm_providers entry points).
# VOLI_LLM_PROVIDER=anthropic
# VOLI_LLM_MODEL=claude-sonnet-4-6

# ----- optional Polygon settings ----------------------------------------------

# Print every Polygon HTTP request/response. Useful when something hangs.
# POLYGON_HTTP_DEBUG=1

# ----- caching / traces -------------------------------------------------------

# VOLI_CACHE_PATH=~/.voli/cache.sqlite
# VOLI_TRACE_DIR=~/.voli/traces

# ----- CLI presentation -------------------------------------------------------

# VOLI_THEME=bloomberg
# VOLI_THEME_CURSOR=~/.voli/theme_cursor

# Disable colour output entirely.
# NO_COLOR=1

# ----- logging ----------------------------------------------------------------

# VOLI_LOG_LEVEL=INFO
# VOLI_LOG_FORMAT=text
