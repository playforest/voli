    "list_option_contracts": {
      "input_schema": {
        "additionalProperties": false,
        "description": "List option contracts for an underlying with optional expiry/right/strike filters.",
        "examples": [
          {
            "expiry": "2026-01-16",
            "limit": 200,
            "right": "C",
            "ticker": "NVDA"
          },
          {
            "limit": 500,
            "strike_max": 520,
            "strike_min": 400,
            "ticker": "SPY"
          }
        ],
        "properties": {
          "expiry": {
            "anyOf": [
              {
                "format": "date",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Expiry date (YYYY-MM-DD)",
            "title": "Expiry"
          },
          "limit": {
            "default": 500,
            "description": "Max number of contracts to return",
            "maximum": 5000,
            "minimum": 1,
            "title": "Limit",
            "type": "integer"
          },
          "right": {
            "anyOf": [
              {
                "enum": [
                  "C",
                  "P"
                ],
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "'C' for calls, 'P' for puts",
            "title": "Right"
          },
          "strike_max": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Maximum strike (inclusive intent)",
            "title": "Strike Max"
          },
          "strike_min": {
            "anyOf": [
              {
                "exclusiveMinimum": 0,
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "Minimum strike (inclusive intent)",
            "title": "Strike Min"
          },
          "ticker": {
            "description": "Underlying ticker, e.g. NVDA",
            "minLength": 1,
            "title": "Ticker",
            "type": "string"
          }
        },
        "required": [
          "ticker"
        ],
        "title": "ListOptionContractsInput",
        "type": "object"
      },
      "output_schema": {
        "$defs": {
          "OptionContract": {
            "additionalProperties": false,
            "properties": {
              "currency": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": "USD",
                "description": "Quote currency if known",
                "title": "Currency"
              },
              "exercise_style": {
                "anyOf": [
                  {
                    "enum": [
                      "american",
                      "european"
                    ],
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
