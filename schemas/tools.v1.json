            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "UTC timestamp (ISO-8601). If None, use latest available.",
            "title": "Asof"
          },
          "ticker": {
            "description": "Underlying ticker, e.g. NVDA",
            "minLength": 1,
            "title": "Ticker",
            "type": "string"
          }
        },
        "required": [
          "ticker"
        ],
        "title": "GetUnderlyingSnapshotInput",
        "type": "object"
      },
      "output_schema": {
        "$defs": {
          "ToolMeta": {
            "additionalProperties": false,
            "description": "Standard metadata included in every tool response.",
            "properties": {
              "asof": {
                "anyOf": [
                  {
                    "format": "date-time",
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Requested asof timestamp (UTC) or None for latest",
                "title": "Asof"
              },
              "generated_at": {
                "description": "When this response was produced (UTC)",
                "format": "date-time",
                "title": "Generated At",
                "type": "string"
              },
              "primary_source": {
                "description": "Primary datasource used",
                "enum": [
                  "polygon",
                  "cache",
                  "synthetic"
                ],
                "title": "Primary Source",
                "type": "string"
              },
              "tool": {
                "description": "Tool name",
                "enum": [
                  "get_underlying_snapshot",
                  "list_option_contracts",
                  "get_option_quotes",
                  "get_option_greeks",
                  "get_option_oi"
                ],
                "title": "Tool",
                "type": "string"
              },
              "warnings": {
                "description": "Non-fatal issues / caveats",
                "items": {
                  "enum": [
                    "NO_RESULTS",
                    "MARKET_CLOSED",
                    "STALE_DATA",
                    "PARTIAL_DATA",
                    "VENDOR_LIMIT"
                  ],
                  "type": "string"
                },
                "title": "Warnings",
                "type": "array"
              }
            },
            "required": [
              "tool",
              "generated_at",
              "primary_source"
            ],
            "title": "ToolMeta",
            "type": "object"
          },
          "UnderlyingSnapshot": {
            "additionalProperties": false,
            "properties": {
              "source": {
                "enum": [
                  "polygon",
                  "cache",
                  "synthetic"
                ],
                "title": "Source",
                "type": "string"
              },
              "spot": {
                "description": "Underlying last/spot price",
                "exclusiveMinimum": 0,
                "title": "Spot",
                "type": "number"
              },
              "ticker": {
                "description": "Underlying ticker, e.g. NVDA",
                "minLength": 1,
                "title": "Ticker",
                "type": "string"
              },
              "ts": {
                "description": "Timestamp of snapshot (UTC)",
                "format": "date-time",
                "title": "Ts",
