{
  "tools": {
    "get_option_greeks": {
      "input_schema": {
        "additionalProperties": false,
        "description": "Fetch or compute greeks/IV for a list of option symbols at an optional UTC time.",
        "examples": [
          {
            "option_symbols": [
              "O:NVDA260116C00120000"
            ]
          },
          {
            "asof": "2025-12-25T00:00:00Z",
            "option_symbols": [
              "O:NVDA260116C00120000"
            ]
          }
        ],
        "properties": {
          "asof": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "UTC timestamp (ISO-8601). If None, use latest available.",
            "title": "Asof"
          },
          "mode": {
            "default": "vendor_only",
            "description": "How to source greeks. 'vendor_only' returns vendor greeks/IV when available. 'vendor_then_bs' allows a fallback compute step (implemented later) if vendor greeks missing",
            "enum": [
              "vendor_only",
              "vendor_then_bs"
            ],
            "title": "Mode",
            "type": "string"
          },
          "option_symbols": {
            "description": "List of option symbols (non-empty)",
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "title": "Option Symbols",
            "type": "array"
          }
        },
        "required": [
          "option_symbols"
        ],
        "title": "GetOptionGreeksInput",
        "type": "object"
      },
      "output_schema": {
        "$defs": {
          "OptionGreeks": {
            "additionalProperties": false,
            "properties": {
              "delta": {
                "anyOf": [
                  {
                    "maximum": 1,
                    "minimum": -1,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Delta"
              },
              "gamma": {
                "anyOf": [
                  {
                    "minimum": 0,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Gamma"
              },
              "iv": {
                "anyOf": [
                  {
                    "minimum": 0,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Implied vol as DECIMAL, e.g. 0.42",
                "title": "Iv"
              },
              "model": {
                "anyOf": [
                  {
                    "enum": [
                      "vendor",
                      "black_scholes"
                    ],
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Model"
              },
              "option_symbol": {
                "minLength": 1,
                "title": "Option Symbol",
                "type": "string"
              },
              "source": {
                "enum": [
                  "polygon",
                  "cache",
                  "synthetic"
                ],
                "title": "Source",
                "type": "string"
              },
              "theta": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Theta"
              },
              "ts": {
                "format": "date-time",
                "title": "Ts",
                "type": "string"
              },
              "vega": {
                "anyOf": [
                  {
                    "minimum": 0,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Vega"
              }
            },
            "required": [
              "option_symbol",
              "ts",
              "source"
            ],
            "title": "OptionGreeks",
            "type": "object"
          },
          "ToolMeta": {
            "additionalProperties": false,
            "description": "Standard metadata included in every tool response.",
            "properties": {
              "asof": {
                "anyOf": [
                  {
                    "format": "date-time",
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Requested asof timestamp (UTC) or None for latest",
                "title": "Asof"
              },
              "generated_at": {
                "description": "When this response was produced (UTC)",
                "format": "date-time",
                "title": "Generated At",
                "type": "string"
              },
              "primary_source": {
                "description": "Primary datasource used",
                "enum": [
                  "polygon",
                  "cache",
                  "synthetic"
                ],
                "title": "Primary Source",
                "type": "string"
              },
              "tool": {
                "description": "Tool name",
                "enum": [
                  "get_underlying_snapshot",
                  "list_option_contracts",
                  "get_option_quotes",
                  "get_option_greeks",
                  "get_option_oi"
                ],
                "title": "Tool",
                "type": "string"
              },
              "warnings": {
                "description": "Non-fatal issues / caveats",
                "items": {
                  "enum": [
                    "NO_RESULTS",
                    "MARKET_CLOSED",
                    "STALE_DATA",
                    "PARTIAL_DATA",
                    "VENDOR_LIMIT"
                  ],
                  "type": "string"
                },
                "title": "Warnings",
                "type": "array"
              }
            },
            "required": [
              "tool",
              "generated_at",
              "primary_source"
            ],
            "title": "ToolMeta",
            "type": "object"
          }
        },
        "additionalProperties": false,
        "description": "Greeks/IV for the requested option symbols.",
        "examples": [
          {
            "greeks": [
              {
                "delta": 0.55,
                "gamma": 0.02,
                "iv": 0.42,
                "model": "vendor",
                "option_symbol": "O:NVDA260116C00120000",
                "source": "polygon",
                "theta": -0.1,
                "ts": "2025-12-25T00:00:00Z",
                "vega": 0.12
              }
            ]
          }
        ],
        "properties": {
          "greeks": {
            "items": {
              "$ref": "#/$defs/OptionGreeks"
            },
            "title": "Greeks",
            "type": "array"
          },
          "meta": {
            "$ref": "#/$defs/ToolMeta"
          }
        },
        "required": [
          "meta",
          "greeks"
        ],
        "title": "GetOptionGreeksOutput",
        "type": "object"
      }
    },
    "get_option_oi": {
      "input_schema": {
        "additionalProperties": false,
        "description": "Fetch open interest for a list of option symbols (if available).",
        "examples": [
          {
            "option_symbols": [
              "O:NVDA260116C00120000"
            ]
          }
        ],
        "properties": {
          "option_symbols": {
            "description": "List of option symbols (non-empty)",
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "title": "Option Symbols",
            "type": "array"
          }
        },
        "required": [
          "option_symbols"
        ],
        "title": "GetOptionOIInput",
        "type": "object"
      },
      "output_schema": {
        "$defs": {
          "OptionOI": {
            "additionalProperties": false,
            "description": "Open interest point for a single option symbol.",
            "examples": [
              {
                "open_interest": 12345,
                "option_symbol": "O:NVDA260116C00120000",
                "source": "polygon",
                "ts": "2025-12-25T00:00:00Z"
              }
            ],
            "properties": {
              "open_interest": {
                "anyOf": [
                  {
                    "minimum": 0,
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Open interest if known",
                "title": "Open Interest"
              },
              "option_symbol": {
                "description": "Option symbol",
                "minLength": 1,
                "title": "Option Symbol",
                "type": "string"
              },
              "source": {
                "default": "polygon",
                "description": "Where the value came from",
                "enum": [
                  "polygon",
                  "cache",
                  "synthetic"
                ],
                "title": "Source",
                "type": "string"
              },
              "ts": {
                "anyOf": [
                  {
                    "format": "date-time",
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "UTC timestamp if known",
                "title": "Ts"
              }
            },
            "required": [
              "option_symbol"
            ],
            "title": "OptionOI",
            "type": "object"
          },
          "ToolMeta": {
            "additionalProperties": false,
            "description": "Standard metadata included in every tool response.",
            "properties": {
              "asof": {
                "anyOf": [
                  {
                    "format": "date-time",
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Requested asof timestamp (UTC) or None for latest",
                "title": "Asof"
              },
              "generated_at": {
                "description": "When this response was produced (UTC)",
                "format": "date-time",
                "title": "Generated At",
                "type": "string"
              },
              "primary_source": {
                "description": "Primary datasource used",
                "enum": [
                  "polygon",
                  "cache",
                  "synthetic"
                ],
                "title": "Primary Source",
                "type": "string"
              },
              "tool": {
                "description": "Tool name",
                "enum": [
                  "get_underlying_snapshot",
                  "list_option_contracts",
                  "get_option_quotes",
                  "get_option_greeks",
                  "get_option_oi"
                ],
                "title": "Tool",
                "type": "string"
              },
              "warnings": {
                "description": "Non-fatal issues / caveats",
                "items": {
                  "enum": [
                    "NO_RESULTS",
                    "MARKET_CLOSED",
                    "STALE_DATA",
                    "PARTIAL_DATA",
                    "VENDOR_LIMIT"
                  ],
                  "type": "string"
                },
                "title": "Warnings",
                "type": "array"
              }
            },
            "required": [
              "tool",
              "generated_at",
              "primary_source"
            ],
            "title": "ToolMeta",
            "type": "object"
          }
        },
        "additionalProperties": false,
        "description": "Open interest results for the requested option symbols.",
        "examples": [
          {
            "oi": [
              {
                "open_interest": 12345,
                "option_symbol": "O:NVDA260116C00120000"
              }
            ]
          }
        ],
        "properties": {
          "meta": {
            "$ref": "#/$defs/ToolMeta"
          },
          "oi": {
            "items": {
              "$ref": "#/$defs/OptionOI"
            },
            "title": "Oi",
            "type": "array"
          }
        },
        "required": [
          "meta",
          "oi"
        ],
        "title": "GetOptionOIOutput",
        "type": "object"
      }
    },
    "get_option_quotes": {
      "input_schema": {
        "additionalProperties": false,
        "description": "Fetch bid/ask/last (and compute mid) for a list of option symbols at an optional UTC time.",
        "examples": [
          {
            "option_symbols": [
              "O:NVDA260116C00120000"
            ]
          },
          {
            "asof": "2025-12-25T00:00:00Z",
            "option_symbols": [
              "O:NVDA260116C00120000",
              "O:NVDA260116P00120000"
            ]
          }
        ],
        "properties": {
          "asof": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "UTC timestamp (ISO-8601). If None, use latest available.",
            "title": "Asof"
          },
          "option_symbols": {
            "description": "List of option symbols (non-empty)",
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "title": "Option Symbols",
            "type": "array"
          }
        },
        "required": [
          "option_symbols"
        ],
        "title": "GetOptionQuotesInput",
        "type": "object"
      },
      "output_schema": {
        "$defs": {
          "OptionQuote": {
            "additionalProperties": false,
            "properties": {
              "ask": {
                "anyOf": [
                  {
                    "minimum": 0,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Ask"
              },
              "bid": {
                "anyOf": [
                  {
                    "minimum": 0,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Bid"
              },
              "last": {
                "anyOf": [
                  {
                    "minimum": 0,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Last"
              },
              "mid": {
                "anyOf": [
                  {
                    "minimum": 0,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "(bid+ask)/2 when both present",
                "title": "Mid"
              },
              "option_symbol": {
                "minLength": 1,
                "title": "Option Symbol",
                "type": "string"
              },
              "source": {
                "enum": [
                  "polygon",
                  "cache",
                  "synthetic"
                ],
                "title": "Source",
                "type": "string"
              },
              "ts": {
                "format": "date-time",
                "title": "Ts",
                "type": "string"
              }
            },
            "required": [
              "option_symbol",
              "ts",
              "source"
            ],
            "title": "OptionQuote",
            "type": "object"
          },
          "ToolMeta": {
            "additionalProperties": false,
            "description": "Standard metadata included in every tool response.",
            "properties": {
              "asof": {
                "anyOf": [
                  {
                    "format": "date-time",
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Requested asof timestamp (UTC) or None for latest",
                "title": "Asof"
              },
              "generated_at": {
                "description": "When this response was produced (UTC)",
                "format": "date-time",
                "title": "Generated At",
                "type": "string"
              },
              "primary_source": {
                "description": "Primary datasource used",
                "enum": [
                  "polygon",
                  "cache",
                  "synthetic"
                ],
                "title": "Primary Source",
                "type": "string"
              },
              "tool": {
                "description": "Tool name",
                "enum": [
                  "get_underlying_snapshot",
                  "list_option_contracts",
                  "get_option_quotes",
                  "get_option_greeks",
                  "get_option_oi"
                ],
                "title": "Tool",
                "type": "string"
              },
              "warnings": {
                "description": "Non-fatal issues / caveats",
                "items": {
                  "enum": [
                    "NO_RESULTS",
                    "MARKET_CLOSED",
                    "STALE_DATA",
                    "PARTIAL_DATA",
                    "VENDOR_LIMIT"
                  ],
                  "type": "string"
                },
                "title": "Warnings",
                "type": "array"
              }
            },
            "required": [
              "tool",
              "generated_at",
              "primary_source"
            ],
            "title": "ToolMeta",
            "type": "object"
          }
        },
        "additionalProperties": false,
        "description": "Quotes for the requested option symbols.",
        "examples": [
          {
            "quotes": [
              {
                "ask": 10.5,
                "bid": 10.0,
                "last": 10.2,
                "mid": 10.25,
                "option_symbol": "O:NVDA260116C00120000",
                "source": "polygon",
                "ts": "2025-12-25T00:00:00Z"
              }
            ]
          }
        ],
        "properties": {
          "meta": {
            "$ref": "#/$defs/ToolMeta"
          },
          "quotes": {
            "items": {
              "$ref": "#/$defs/OptionQuote"
            },
            "title": "Quotes",
            "type": "array"
          }
        },
        "required": [
          "meta",
          "quotes"
        ],
        "title": "GetOptionQuotesOutput",
        "type": "object"
      }
    },
    "get_underlying_snapshot": {
      "input_schema": {
        "additionalProperties": false,
        "description": "Fetch a spot/last price snapshot for an underlying ticker at an optional UTC time.",
        "examples": [
          {
            "ticker": "NVDA"
          },
          {
            "asof": "2025-12-25T00:00:00Z",
